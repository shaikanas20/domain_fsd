{
  "info": {
    "_postman_id": "cinereserve-api-collection",
    "name": "CineReserve API Gateway Endpoints",
    "description": "API collection for CineReserve microservices, routing via API Gateway on port 8080.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentication Service",
      "item": [
        {
          "name": "User Registration",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Owner\",\n  \"email\": \"owner@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"THEATRE_OWNER\",\n  \"phone\": \"1234567890\"\n}"
            },
            "url": {
              "raw": "http://localhost:8080/auth/register",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["auth", "register"]
            }
          }
        },
        {
          "name": "User Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"owner@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "http://localhost:8080/auth/login",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "Refresh Access Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"paste-refresh-token-uuid-here\"\n}"
            },
            "url": {
              "raw": "http://localhost:8080/auth/refresh",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["auth", "refresh"]
            }
          }
        },
        {
          "name": "Get User Profile",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "http://localhost:8080/auth/profile",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["auth", "profile"]
            }
          }
        }
      ]
    },
    {
      "name": "Catalog Service",
      "item": [
        {
          "name": "Create Location",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Downtown IMAX Center\",\n  \"city\": \"Chicago\",\n  \"state\": \"IL\"\n}"
            },
            "url": {
              "raw": "http://localhost:8080/locations",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["locations"]
            }
          }
        },
        {
          "name": "Register Theatre",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Midtown Grand Cinema\",\n  \"locationId\": \"paste-location-id-here\",\n  \"address\": \"789 Michigan Ave\"\n}"
            },
            "url": {
              "raw": "http://localhost:8080/theatres",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["theatres"]
            }
          }
        },
        {
          "name": "Approve Theatre (Admin)",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "http://localhost:8080/theatres/paste-theatre-id-here/approve?status=APPROVED",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["theatres", "paste-theatre-id-here", "approve"],
              "query": [
                {
                  "key": "status",
                  "value": "APPROVED"
                }
              ]
            }
          }
        },
        {
          "name": "Add Movie to Catalog",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Gladiator II\",\n  \"description\": \"Years after witnessing the death of the revered hero Maximus...\",\n  \"genres\": [\"Action\", \"Drama\", \"Adventure\"],\n  \"duration\": 148,\n  \"rating\": 8.2,\n  \"languages\": [\"English\"],\n  \"releaseDate\": \"2024-11-22\",\n  \"poster\": \"https://example.com/gladiator2.jpg\",\n  \"trailer\": \"https://youtube.com/watch?v=...\",\n  \"status\": \"NOW_SHOWING\"\n}"
            },
            "url": {
              "raw": "http://localhost:8080/movies",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["movies"]
            }
          }
        }
      ]
    },
    {
      "name": "Booking Service",
      "item": [
        {
          "name": "Create Scheduled Show",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"movieId\": \"paste-movie-id-here\",\n  \"screenId\": \"paste-screen-id-here\",\n  \"theatreId\": \"paste-theatre-id-here\",\n  \"showDate\": \"2026-06-20\",\n  \"startTime\": \"18:00:00\",\n  \"endTime\": \"20:30:00\",\n  \"priceMap\": {\n    \"NORMAL\": 15.00,\n    \"VIP\": 30.00\n  },\n  \"seats\": [\n    { \"seatNumber\": \"A1\", \"seatType\": \"NORMAL\" },\n    { \"seatNumber\": \"A2\", \"seatType\": \"NORMAL\" },\n    { \"seatNumber\": \"B1\", \"seatType\": \"VIP\" }\n  ]\n}"
            },
            "url": {
              "raw": "http://localhost:8080/booking/shows",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["booking", "shows"]
            }
          }
        },
        {
          "name": "Initiate Ticket Booking (Lock Seats)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"showId\": 1,\n  \"seatNumbers\": [\"A1\", \"A2\"]\n}"
            },
            "url": {
              "raw": "http://localhost:8080/booking/initiate",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["booking", "initiate"]
            }
          }
        },
        {
          "name": "Confirm Ticket Booking (Pay)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "http://localhost:8080/booking/confirm/1",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["booking", "confirm", "1"]
            }
          }
        }
      ]
    }
  ]
}
